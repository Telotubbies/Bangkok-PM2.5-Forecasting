# ─── Supabase ─────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com/dashboard
# Then copy the URL and anon key from Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJI...your-anon-key

# ─── Hugging Face Inference ───────────────────────────────────────────────────
# Deploy the ST-UNN model to HF Inference Endpoints or Spaces
# https://huggingface.co/docs/inference-endpoints
VITE_HF_INFERENCE_URL=https://api-inference.huggingface.co/models/your-org/stunn-pm25
VITE_HF_API_TOKEN=hf_...your-token

# ─── Optional: Analytics ──────────────────────────────────────────────────────
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
